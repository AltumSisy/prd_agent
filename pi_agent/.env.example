# SAP Connection Configuration
SAP_HOST=your-sap-host
SAP_CLIENT=your-client-id
SAP_USER=your-username
SAP_PASSWORD=your-password
SAP_PORT=8000
SAP_SSL=no

# Python path for sapcli (optional)
